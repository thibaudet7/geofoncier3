          async function loadArrondissements() {
            const loadingSpinner = document.getElementById('arrondissementLoading');
            const filterSelect = document.getElementById('filterArrondissement');
            
            try {
                loadingSpinner.style.display = 'inline-block';
                
                console.log('🔄 Chargement des arrondissements depuis Supabase...');
                
                // Charger depuis l'API avec les vraies données
                const response = await fetch('/api/spatial/arrondissements');
                if (!response.ok) {
                    throw new Error(`Erreur API: ${response.status} - ${response.statusText}`);
                }
                
                const data = await response.json();
                arrondissementsData = data.arrondissements || [];
                
                console.log(`✅ ${arrondissementsData.length} arrondissements chargés depuis la base de données`);
        
                // Nettoyer la couche existante
                arrondissementLayer.clearLayers();
                
                // Populer le select des filtres
                filterSelect.innerHTML = '<option value="">Tous les arrondissements</option>';
                
                // Compteurs pour le debug
                let polygonsCreated = 0;
                let polygonsSkipped = 0;
                let coordinateErrors = 0;
                
                // Ajouter les arrondissements à la carte
                arrondissementsData.forEach((arrondissement, index) => {
                    console.log(`📍 Traitement ${index + 1}/${arrondissementsData.length}: ${arrondissement.nom_arrondissement}`);
                    
                    // Ajouter au select
                    const option = document.createElement('option');
                    option.value = arrondissement.nom_arrondissement;
                    option.textContent = arrondissement.nom_arrondissement;
                    filterSelect.appendChild(option);
                    
                    // Traiter la géométrie PostGIS - UTILISER LE BON CHAMP
                    let coordinates = [];
                    const geomData = arrondissement.geom_wkt || arrondissement.geom;
                    if (geomData) {
                        coordinates = parsePostGISGeometry(geomData);
                        console.log(`🗺️ ${arrondissement.nom_arrondissement}: ${coordinates.length} coordonnées parsées`);
                    } else {
                        console.warn(`⚠️ Pas de géométrie pour ${arrondissement.nom_arrondissement}`);
                    }
                    
                    // Créer le polygone seulement si on a des coordonnées valides
                    if (coordinates.length >= 3) {
                        
                        // VÉRIFICATION : S'assurer qu'aucune coordonnée n'est NaN ou invalide
                        const hasInvalidCoords = coordinates.some(coord => 
                            !coord || coord.length !== 2 ||
                            isNaN(coord[0]) || isNaN(coord[1]) || 
                            coord[0] < -90 || coord[0] > 90 || 
                            coord[1] < -180 || coord[1] > 180
                        );
                        
                        if (hasInvalidCoords) {
                            console.error(`❌ Coordonnées invalides détectées pour ${arrondissement.nom_arrondissement}`);
                            console.log('Échantillon coordonnées problématiques:', coordinates.slice(0, 3));
                            coordinateErrors++;
                            return; // Skip ce polygone
                        }
                        
                        console.log(`✅ ${arrondissement.nom_arrondissement}: ${coordinates.length} coordonnées valides`);
                        
                        try {
                            const polygon = L.polygon(coordinates, {
                                color: '#2c3e50',           // Bordure bleu foncé
                                weight: 2,                  // Épaisseur bordure
                                fillOpacity: 0.05,          // Très transparent (5%)
                                fillColor: '#3498db',       // Remplissage bleu
                                opacity: 1                  // Bordure bien visible
                            });
        
                            // Calculer la superficie en km² - LOGIQUE CORRIGÉE
                            let areaKm2;
                            if (arrondissement.superficie_km2) {
                                // Utiliser la superficie précalculée depuis la base de données
                                areaKm2 = parseFloat(arrondissement.superficie_km2).toFixed(2);
                            } else {
                                // Calculer avec notre fonction
                                const area = calculatePolygonArea(coordinates);
                                areaKm2 = (area / 1000000).toFixed(2);
                            }
        
                            // Popup avec informations détaillées - SANS "Données officielles Supabase"
                            const popupContent = `
                                <div style="text-align: center; min-width: 200px;">
                                    <h4 style="margin-bottom: 0.5rem; color: #2c3e50;">
                                        <i class="fas fa-map-marker-alt"></i> ${arrondissement.nom_arrondissement}
                                    </h4>
                                    <div style="text-align: left; font-size: 0.9rem;">
                                        ${arrondissement.nom_departement ? `
                                            <p><strong>Département:</strong> ${arrondissement.nom_departement}</p>
                                        ` : ''}
                                        ${arrondissement.nom_region ? `
                                            <p><strong>Région:</strong> ${arrondissement.nom_region}</p>
                                        ` : ''}
                                        ${arrondissement.name ? `
                                            <p><strong>Quartier principal:</strong> ${arrondissement.name}</p>
                                        ` : ''}
                                        <p><strong>Superficie:</strong> ${areaKm2} km²</p>
                                    </div>
                                </div>
                            `;
                            
                            polygon.bindPopup(popupContent);
                            
                            // Événements d'interaction
                            polygon.on('mouseover', function(e) {
                                this.setStyle({
                                    weight: 3,
                                    fillOpacity: 0.15,
                                    color: '#e74c3c'
                                });
                            });
                            
                            polygon.on('mouseout', function(e) {
                                this.setStyle({
                                    weight: 2,
                                    fillOpacity: 0.05,
                                    color: '#2c3e50'
                                });
                            });
                            
                            // Clic pour zoomer sur l'arrondissement
                            polygon.on('click', function(e) {
                                map.fitBounds(polygon.getBounds(), {
                                    padding: [10, 10]
                                });
                            });
                            
                            // Ajouter à la couche
                            arrondissementLayer.addLayer(polygon);
                            polygonsCreated++;
                            
                            console.log(`✅ Polygone ${polygonsCreated} créé pour ${arrondissement.nom_arrondissement}`);
                            
                        } catch (leafletError) {
                            console.error(`❌ Erreur création polygone Leaflet pour ${arrondissement.nom_arrondissement}:`, leafletError);
                            polygonsSkipped++;
                        }
                        
                    } else {
                        console.warn(`❌ Impossible de créer le polygone pour ${arrondissement.nom_arrondissement} (${coordinates.length} coordonnées)`);
                        polygonsSkipped++;
                    }
                });
        
                // Rapport final
                console.log(`\n🎉 RAPPORT FINAL:`);
                console.log(`📊 Arrondissements traités: ${arrondissementsData.length}`);
                console.log(`✅ Polygones créés: ${polygonsCreated}`);
                console.log(`⚠️ Polygones ignorés: ${polygonsSkipped}`);
                console.log(`❌ Erreurs coordonnées: ${coordinateErrors}`);
                console.log(`🗂️ Couche contient: ${arrondissementLayer.getLayers().length} éléments`);
        
                // Message de succès
                let message;
                if (polygonsCreated > 0) {
                    message = `${polygonsCreated} arrondissements affichés sur la carte`;
                    if (polygonsSkipped > 0) {
                        message += ` (${polygonsSkipped} ignorés)`;
                    }
                    showNotification(message, 'success');
                } else {
                    message = `Aucun arrondissement affiché (${polygonsSkipped + coordinateErrors} erreurs)`;
                    showNotification(message, 'error');
                }
                
                console.log(`🎉 ${message}`);
                
                // Ajuster la vue de la carte pour montrer tous les arrondissements
                if (polygonsCreated > 0) {
                    setTimeout(() => {
                        try {
                            const bounds = arrondissementLayer.getBounds();
                            if (bounds.isValid()) {
                                map.fitBounds(bounds, {
                                    padding: [20, 20]
                                });
                                console.log('✅ Carte centrée sur les arrondissements');
                            } else {
                                console.warn('⚠️ Bounds invalides, centrage sur Douala');
                                map.setView([4.0511, 9.7679], 10);
                            }
                        } catch (boundsError) {
                            console.warn('⚠️ Erreur centrage carte:', boundsError);
                            // Centrer sur le Cameroun par défaut
                            map.setView([7.3697, 12.3547], 6);
                        }
                    }, 500);
                } else {
                    console.warn('⚠️ Aucun polygone créé - pas de centrage automatique');
                }
                
            } catch (error) {
                console.error('❌ Erreur chargement arrondissements:', error);
                showNotification(`Erreur: ${error.message}`, 'error');
                
                // Afficher des détails d'erreur pour le debug
                if (error.message.includes('API:')) {
                    console.error('🔧 Vérifiez que le serveur backend est démarré sur le port 3000');
                    console.error('🔧 Testez: http://localhost:3000/api/spatial/arrondissements');
                }
            } finally {
                loadingSpinner.style.display = 'none';
            }
        }



/////


